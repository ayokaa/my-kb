# ─── LLM（必需）───
# LLM API 密钥，用于笔记生成和 AI 对话
# 支持 Anthropic Messages API 及兼容端点
# Anthropic 获取地址：https://console.anthropic.com/
ANTHROPIC_API_KEY=your_api_key_here

# LLM API 基地址（可选，默认 Anthropic 官方端点）
# ANTHROPIC_BASE_URL=https://api.minimaxi.com/anthropic

# ─── Web Search（可选）───
# TinyFish 搜索 API 密钥（优先使用）
# 获取地址：https://tinyfish.ai/
# TINYFISH_API_KEY=your_tinyfish_key_here

# Serper (Google) 搜索 API 密钥（备用）
# SEARCH_API_KEY=your_serper_key_here
