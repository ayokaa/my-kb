# ─── LLM（必需）───
# MiniMax API 密钥，用于笔记生成和 AI 对话
# 获取地址：https://www.minimaxi.com/platform
MINIMAX_API_KEY=your_minimax_api_key_here

# MiniMax API 基地址（可选，默认官方端点）
# MINIMAX_BASE_URL=https://api.minimaxi.com/v1

# ─── 网络搜索（可选）───
# 搜索 API 密钥，默认使用 Serper.dev
# 获取地址：https://serper.dev
# SEARCH_API_KEY=your_serper_key_here

# 搜索引擎（可选，默认 serper）
# SEARCH_ENGINE=serper
